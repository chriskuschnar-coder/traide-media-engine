# ============================================
# TRAIDE MEDIA ENGINE - Environment Variables
# Copy this to .env and fill in your keys
# ============================================

# --- CORE AI ---
ANTHROPIC_API_KEY=sk-ant-...          # Claude API (content brain)
REPLICATE_API_TOKEN=r8_...            # Video/image generation (Runway, Stable Video)
ELEVENLABS_API_KEY=...                # AI voiceovers
OPENAI_API_KEY=sk-...                 # DALL-E / backup TTS

# --- TELEGRAM BOT (your command center) ---
TELEGRAM_BOT_TOKEN=...               # From @BotFather
TELEGRAM_CHAT_ID=...                 # Your control chat ID
TELEGRAM_CHANNEL_ID=...              # Public channel for posts

# --- YOUTUBE ---
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# --- X / TWITTER ---
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_SECRET=...
X_BEARER_TOKEN=...

# --- INSTAGRAM (via Meta Graph API) ---
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_BUSINESS_ACCOUNT_ID=...

# --- FACEBOOK ---
FACEBOOK_PAGE_ACCESS_TOKEN=...
FACEBOOK_PAGE_ID=...

# --- TIKTOK ---
TIKTOK_ACCESS_TOKEN=...
TIKTOK_OPEN_ID=...

# --- INFRASTRUCTURE ---
REDIS_URL=redis://localhost:6379
SUPABASE_URL=...                     # Optional: analytics storage
SUPABASE_ANON_KEY=...

# --- TRAIDE.LIVE CONTEXT ---
TRAIDE_WEBSITE_URL=https://traide.live
TRAIDE_APP_URL=https://app.traide.live
TRAIDE_TAGLINE="AI-Powered Trading Intelligence"
