# ============================================
# TRAIDE MEDIA ENGINE - Environment Variables
# Copy this to .env and fill in your keys
# ============================================

# ── PHASE CONTROL ──
ENABLED_PLATFORMS=youtube                # Start with YouTube only. Add: x,tiktok,instagram,facebook,telegram

# ── CORE AI (required) ──
ANTHROPIC_API_KEY=sk-ant-...             # Claude API — the brain. console.anthropic.com

# ── TELEGRAM BOT (required — your command center) ──
TELEGRAM_BOT_TOKEN=...                   # From @BotFather on Telegram
TELEGRAM_CHAT_ID=...                     # Your personal chat ID (message @userinfobot)
TELEGRAM_CHANNEL_ID=...                  # Public channel for posting (optional)

# ── UNIFIED POSTING — Ayrshare (replaces per-platform APIs) ──
AYRSHARE_API_KEY=...                     # ayrshare.com — $69/mo Premium. Posts to all 6 platforms.

# ── VIDEO GENERATION ──
HEYGEN_API_KEY=...                       # heygen.com — AI avatar talking head ($29/mo Creator)
HEYGEN_AVATAR_ID=...                     # Your chosen avatar ID from HeyGen dashboard
ELEVENLABS_API_KEY=...                   # elevenlabs.io — AI voiceovers (free tier to start)
SUBMAGIC_API_KEY=...                     # submagic.co — auto-burn viral captions ($16/mo)

# ── IMAGE GENERATION ──
REPLICATE_API_TOKEN=r8_...               # replicate.com — Flux image gen ($0.01/image)

# ── YOUTUBE (native — kept separate for better quota control) ──
YOUTUBE_CLIENT_ID=...                    # Google Cloud Console → YouTube Data API v3
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...                # OAuth2 flow needed (one-time setup)

# ── INFRASTRUCTURE ──
REDIS_URL=redis://localhost:6379         # brew install redis, or Upstash free tier
SUPABASE_URL=...                         # supabase.com — analytics storage (free tier)
SUPABASE_ANON_KEY=...

# ── TRAIDE.LIVE CONTEXT ──
TRAIDE_WEBSITE_URL=https://traide.live
TRAIDE_APP_URL=https://app.traide.live
TRAIDE_TAGLINE="AI-Powered Trading Intelligence"

# ── COMPLIANCE ──
DISCLAIMER_TEXT="Not financial advice. Trading involves risk. Past performance does not guarantee future results."

# ── X / TWITTER (only if posting direct, not through Ayrshare) ──
# X_API_KEY=...
# X_API_SECRET=...
# X_ACCESS_TOKEN=...
# X_ACCESS_SECRET=...

# ── INSTAGRAM (only if posting direct) ──
# INSTAGRAM_ACCESS_TOKEN=...
# INSTAGRAM_BUSINESS_ACCOUNT_ID=...

# ── FACEBOOK (only if posting direct) ──
# FACEBOOK_PAGE_ACCESS_TOKEN=...
# FACEBOOK_PAGE_ID=...

# ── TIKTOK (only if posting direct) ──
# TIKTOK_ACCESS_TOKEN=...
# TIKTOK_OPEN_ID=...
