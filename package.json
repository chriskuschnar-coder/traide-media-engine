{
  "name": "traide-media-engine",
  "version": "0.2.0",
  "description": "Autonomous AI content creation & distribution engine for traide.live",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bot/telegram.ts",
    "bot": "tsx src/bot/telegram.ts",
    "scheduler": "tsx src/scheduler/index.ts",
    "worker:video": "tsx src/workers/video-worker.ts",
    "worker:post": "tsx src/workers/post-worker.ts",
    "worker:analytics": "tsx src/workers/analytics-puller.ts",
    "setup": "tsx src/setup/check-env.ts",
    "start": "concurrently \"npm:bot\" \"npm:scheduler\" \"npm:worker:*\"",
    "remotion:preview": "remotion preview src/services/media/remotion/composition.tsx",
    "remotion:render": "remotion render src/services/media/remotion/composition.tsx",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "axios": "^1.7.7",
    "bull": "^4.16.0",
    "concurrently": "^9.0.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "elevenlabs": "^1.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "replicate": "^1.0.1",
    "sharp": "^0.33.5",
    "telegraf": "^4.16.3",
    "twitter-api-v2": "^1.29.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/node": "^22.5.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
